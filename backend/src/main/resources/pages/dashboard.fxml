<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.app.ui.controller.DashboardController">
    <top>
        <HBox fx:id="header" spacing="16" alignment="CENTER_LEFT" styleClass="header" BorderPane.alignment="CENTER">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="BV" styleClass="brand-icon" />
                <Label text="BidVault" styleClass="brand" />
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER" spacing="18">
                <Label text="Home" styleClass="nav-label" />
                <Label fx:id="inventoryLabel" text="Inventory" styleClass="nav-label" onMouseClicked="#onInventory" />
                <Label text="Explore" styleClass="nav-label" />
            </HBox>
            <Button fx:id="signInButton" text="Sign In" styleClass="login-button" onAction="#onLogin" />
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <VBox spacing="56" alignment="TOP_CENTER" styleClass="content-pane">
                <VBox.margin>
                    <Insets top="40" left="32" bottom="32" right="32" />
                </VBox.margin>
                <VBox spacing="24" alignment="CENTER" maxWidth="1000" styleClass="hero-section">
                    <Label text="Premium bidding experience" styleClass="hero-eyebrow" />
                    <Label text="Discover a world where every bid leads to excellence" styleClass="hero-title" wrapText="true" textAlignment="CENTER" />
                </VBox>

                <VBox spacing="24" alignment="CENTER_LEFT" maxWidth="1100" styleClass="preview-section">
                    <VBox spacing="12" alignment="CENTER_LEFT">
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="Active Auctions" styleClass="section-title" />
                            <Label text="Recently ->" styleClass="section-subtitle" />
                        </HBox>
                        <FlowPane fx:id="activeContainer" hgap="20" vgap="20" prefWrapLength="1100" />
                    </VBox>

                    <VBox spacing="12" alignment="CENTER_LEFT">
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="Ended Auctions" styleClass="section-title" />
                            <Label text="Recently ->" styleClass="section-subtitle" />
                        </HBox>
                        <FlowPane fx:id="endedContainer" hgap="20" vgap="20" prefWrapLength="1100" />
                    </VBox>

                    <VBox spacing="12" alignment="CENTER_LEFT">
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="Upcoming Auctions" styleClass="section-title" />
                            <Label text="Recently ->" styleClass="section-subtitle" />
                        </HBox>
                        <FlowPane fx:id="upcomingContainer" hgap="20" vgap="20" prefWrapLength="1100" />
                    </VBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" styleClass="footer" BorderPane.alignment="CENTER">
            <Label text="© 2026 BidVault — Crafted for premium auctions" />
        </HBox>
    </bottom>
</BorderPane>
