<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.app.controllers.account.balance.TransactionHistoryBoxController"
      spacing="15.0"
      style="-fx-background-color: #1E293B; -fx-background-radius: 12px; -fx-border-color: #334155; -fx-border-radius: 12px; -fx-border-width: 1px;"
      prefWidth="790.0">

    <padding>
        <Insets top="25.0" right="25.0" bottom="25.0" left="25.0"/>
    </padding>

    <Label text="Transaction History" textFill="#F8FAFC">
        <font>
            <Font name="System Bold" size="18.0"/>
        </font>
    </Label>

    <!-- ✅ FIX 3: Defined TableColumns so data actually renders in the table -->
    <TableView fx:id="transactionTable"
               stylesheets="@../../../styles/tableview.css"
               prefHeight="280.0"
               style="-fx-background-color: transparent;">
        <columns>
            <TableColumn fx:id="typeColumn"   text="Type"   prefWidth="120.0"/>
            <TableColumn fx:id="amountColumn" text="Amount" prefWidth="140.0"/>
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="130.0"/>
            <TableColumn fx:id="dateColumn"   text="Date"   prefWidth="190.0"/>
        </columns>
    </TableView>

    <!-- ✅ FIX 4: Added pagination controls that the controller already wires up -->
    <HBox alignment="CENTER" spacing="15.0">
        <Button fx:id="previousPageButton" text="← Prev" onAction="#loadPreviousPage"
                style="-fx-background-color: #334155; -fx-text-fill: #F8FAFC; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-cursor: hand;">
            <padding>
                <Insets top="8.0" right="16.0" bottom="8.0" left="16.0"/>
            </padding>
        </Button>
        <Label fx:id="pageIndexIndicatorLabel" text="Page 1 of 1" textFill="#94A3B8"/>
        <Button fx:id="nextPageButton" text="Next →" onAction="#loadNextPage"
                style="-fx-background-color: #334155; -fx-text-fill: #F8FAFC; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-cursor: hand;">
            <padding>
                <Insets top="8.0" right="16.0" bottom="8.0" left="16.0"/>
            </padding>
        </Button>
    </HBox>

</VBox>
