<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.app.controllers.account.balance.BalanceRequestBoxController"
      style="-fx-background-color: #1E293B; -fx-background-radius: 12px; -fx-border-color: #38BDF8; -fx-border-width: 1.5px; -fx-border-radius: 12px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.5), 15, 0, 0, 0);"
      maxWidth="400.0" maxHeight="280.0" prefWidth="400.0" spacing="20.0" alignment="CENTER">
    <padding>
        <Insets top="25.0" right="25.0" bottom="25.0" left="25.0"/>
    </padding>

    <VBox spacing="6.0" alignment="CENTER_LEFT">
        <Label fx:id="modalTitleLabel" text="TRANSACTION REQUEST" textFill="#F8FAFC">
            <font>
                <Font name="System Bold" size="18.0"/>
            </font>
        </Label>
        <Label fx:id="modalDescriptionLabel" text="Provide an amount to forward to the platform admin ledger." textFill="#94A3B8" wrapText="true">
            <font>
                <Font size="12.0"/>
            </font>
        </Label>
    </VBox>

    <VBox spacing="8.0">
        <Label text="Amount ($)" textFill="#CBD5E1" style="-fx-font-weight: bold;"/>
        <TextField fx:id="amountInputField" promptText="0.00"
                   style="-fx-background-color: #0F172A; -fx-text-fill: white; -fx-prompt-text-fill: #475569; -fx-background-radius: 6px; -fx-border-color: #334155; -fx-border-radius: 6px;">
            <padding>
                <Insets top="10.0" right="12.0" bottom="10.0" left="12.0"/>
            </padding>
        </TextField>
        <Label fx:id="errorMessageLabel" textFill="#F43F5E" visible="false" wrapText="true" style="-fx-font-size: 11px;"/>
    </VBox>

    <HBox spacing="12.0" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#handleCloseModal"
                style="-fx-background-color: transparent; -fx-text-fill: #94A3B8; -fx-font-weight: bold; -fx-cursor: hand;"/>
        <Button fx:id="actionSubmitButton" text="Confirm Request" onAction="#handleSubmitTransaction"
                style="-fx-background-color: #38BDF8; -fx-text-fill: #0F172A; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-cursor: hand;">
            <padding>
                <Insets top="10.0" right="16.0" bottom="10.0" left="16.0"/>
            </padding>
        </Button>
    </HBox>
</VBox>